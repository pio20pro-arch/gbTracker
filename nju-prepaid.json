{
  "schemaVersion": 1,
  "publishedAt": "2026-03-13T00:00:00Z",
  "minAppVersion": "1.5.0",
  "providerVersion": "nju-prepaid-1",
  "provider": "nju-prepaid",
  "displayName": "nju (abonament, na kartę, internet mobilny)",
  "inputs": {
    "login": {
      "type": "text",
      "label": "Numer telefonu"
    },
    "password": {
      "type": "password",
      "label": "Hasło"
    }
  },
  "endpoints": {
    "loginPage": {
      "method": "GET",
      "url": "https://www.njumobile.pl/logowanie"
    },
    "loginSubmit": {
      "method": "POST",
      "url": "https://www.njumobile.pl/logowanie",
      "contentType": "application/x-www-form-urlencoded"
    },
    "balanceAjax": {
      "method": "POST",
      "url": "https://www.njumobile.pl/ecare-infoservices/ajax?group=home-alerts-state-funds&toGet=home-alerts-state-funds&toUpdate=state-funds-infoservices&pageId=7800013&actionUrl=%2Fmojekonto%2Fstan-konta&parentUrl=%2Fmojekonto&isMobile=false",
      "headers": {
        "Referer": "https://www.njumobile.pl/mojekonto/stan-konta",
        "X-Requested-With": "XMLHttpRequest"
      }
    }
  },
  "flows": {
    "login": [
      {
        "step": "submitLoginForm",
        "type": "formPost",
        "request": "loginSubmit",
        "bodyType": "form",
        "body": {
          "_dyncharset": "UTF-8",
          "_dynSessConf": "{{runtime._dynSessConf}}",
          "/ptk/sun/login/formhandler/LoginFormHandler.backUrl": "",
          "_D:/ptk/sun/login/formhandler/LoginFormHandler.backUrl": "",
          "/ptk/sun/login/formhandler/LoginFormHandler.hashMsisdn": "",
          "_D:/ptk/sun/login/formhandler/LoginFormHandler.hashMsisdn": "",
          "phone-input": "{{input.login}}",
          "_D:phone-input": "",
          "password-form": "{{input.password}}",
          "_D:password-form": "",
          "login-submit": "zaloguj sie",
          "_D:login-submit": "",
          "_DARGS": "/profile-processes/login/login.jsp.portal-login-form"
        }
      }
    ]
  },
  "parse": {
    "expiryDate": {
      "source": "balanceHtml",
      "type": "regexDate",
      "patterns": [
        "\\b\\d{4}-\\d{2}-\\d{2}\\b",
        "\\b\\d{2}\\.\\d{2}\\.\\d{4}\\b"
      ],
      "formats": [
        "yyyy-MM-dd",
        "dd.MM.yyyy"
      ]
    }
  },
  "validity": {
    "zeroUsageWhenExpired": true,
    "compareWithLocalDate": true
  },
  "session": {
    "persistCookies": true,
    "reuseSessionUntilInvalid": true,
    "retryOnExpiredSession": true
  }
}
