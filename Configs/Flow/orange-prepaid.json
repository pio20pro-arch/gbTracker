{
  "schemaVersion": 1,
  "publishedAt": "2026-03-14T16:30:00Z",
  "minAppVersion": "1.5.0",
  "providerVersion": "orange-prepaid-4",
  "provider": "orange-prepaid",
  "displayName": "orange (na kartę)",
  "inputs": {
    "login": {
      "type": "text",
      "label": "Login",
      "accepts": [
        "email",
        "phone"
      ]
    },
    "password": {
      "type": "password",
      "label": "Hasło"
    },
    "otp": {
      "type": "otp",
      "label": "Kod SMS"
    }
  },
  "endpoints": {
    "loginPage": {
      "method": "GET",
      "url": "https://www.orange.pl/twojekonto/"
    },
    "phoneLoginPage": {
      "method": "GET",
      "url": "https://www.orange.pl/twojekonto/zaloguj/numer"
    },
    "loginInit": {
      "method": "POST",
      "url": "https://www.orange.pl/twojekonto/login/init",
      "contentType": "application/json"
    },
    "loginAction": {
      "method": "POST",
      "url": "https://www.orange.pl/twojekonto/login/action",
      "contentType": "application/json"
    },
    "loginCompleted": {
      "method": "POST",
      "url": "https://www.orange.pl/twojekonto/login/completed",
      "contentType": "application/json"
    },
    "registration": {
      "method": "GET",
      "url": "https://www.orange.pl/moj-orange/rejestracja"
    },
    "dashboard": {
      "method": "GET",
      "url": "https://www.orange.pl/moj-orange/uslugi-na-karte"
    },
    "tariff": {
      "method": "GET",
      "url": "https://www.orange.pl/moj-orange/ajax/waspDashTariff/init?_={{runtime.unixTimeMs}}"
    }
  },
  "flows": {
    "login": [
      {
        "step": "initLogin",
        "type": "jsonPost",
        "request": "loginInit",
        "body": {
          "login": "{{input.login}}"
        }
      },
      {
        "step": "submitPassword",
        "type": "jsonPost",
        "request": "loginAction",
        "body": {
          "action": "LOGIN_2FA_PASSWORD",
          "executionId": "{{response.executionId}}",
          "state": "{{response.state}}",
          "login": "{{input.login}}",
          "password": "{{input.password}}"
        }
      },
      {
        "step": "passwordCompleted",
        "type": "branch",
        "when": {
          "response.requireAction": "COMPLETED"
        },
        "then": [
          {
            "step": "openRegistrationAfterPassword",
            "type": "httpGet",
            "request": "registration"
          },
          {
            "step": "openDashboardAfterPassword",
            "type": "httpGet",
            "request": "dashboard"
          }
        ]
      },
      {
        "step": "submitOtp",
        "type": "jsonPost",
        "request": "loginAction",
        "body": {
          "action": "{{runtime.otpAction}}",
          "executionId": "{{runtime.executionId}}",
          "state": "{{runtime.state}}",
          "otp": "{{input.otp}}"
        }
      },
      {
        "step": "completeTrustedDevice",
        "type": "jsonPost",
        "request": "loginCompleted",
        "body": {
          "action": "ADD_DEVICE",
          "state": "{{runtime.stateForCompletion}}",
          "authenticationId": "{{response.authenticationId}}",
          "deviceToken": "{{response.deviceToken}}"
        }
      }
    ]
  },
  "parse": {
    "expiryDate": {
      "source": "tariffHtml",
      "type": "regexDate",
      "pattern": "\\b\\d{2}\\.\\d{2}\\.\\d{4}\\b",
      "format": "dd.MM.yyyy"
    }
  },
  "pageStates": {
    "login": {
      "urlContains": [
        "/twojekonto/"
      ],
      "containsAny": [
        "data-test-id=\"input-login\"",
        "Zaloguj się do Mój Orange",
        "Zaloguj siÄ™ do MÃ³j Orange"
      ]
    },
    "otp": {
      "containsAny": [
        "data-test-id=\"input-otp\"",
        "Podaj kod SMS"
      ]
    },
    "trustedDevice": {
      "containsAny": [
        "data-test-id=\"button-log-in-once\"",
        "Zaloguj jednorazowo",
        "Dodaj urządzenie do zaufanych",
        "Dodaj urzadzenie do zaufanych"
      ]
    },
    "portal": {
      "urlContains": [
        "/moj-orange/"
      ],
      "containsAny": [
        "id=\"__NEXT_DATA__\"",
        "\"page\":\"/moj-orange/uslugi-na-karte\""
      ]
    },
    "usage": {
      "containsAny": [
        "Bonus Internetowy za doładowania",
        "Bonus Internetowy za doÅ‚adowania",
        "Internet w roamingu:",
        "Orange Free na Kartę:",
        "Orange Free na KartÄ™:"
      ]
    }
  },
  "validity": {
    "zeroUsageWhenExpired": true,
    "compareWithLocalDate": true
  },
  "session": {
    "persistCookies": true,
    "persistDeviceToken": true,
    "invalidateTrustedStateWhenUserAgentChanges": true,
    "trustedDevice": {
      "onInitialLogin": true,
      "onReauth": false
    },
    "authenticationOutcomes": {
      "passwordCompletedWithoutSms": "reuse-portal-session",
      "otpCompletedWithoutTrustedDevice": "open-registration-first",
      "otpCompletedWithTrustedDeviceFallback": "allowed"
    }
  }
}
